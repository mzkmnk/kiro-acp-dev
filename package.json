{
  "name": "kiro-acp-dev",
  "displayName": "Kiro ACP",
  "description": "Kiro AI agent chat panel for VSCode via ACP",
  "version": "0.1.0",
  "publisher": "m4i",
  "license": "MIT",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "kiro-acp",
          "title": "KIRO-CLI",
          "icon": "media/kiro-icon.svg"
        }
      ]
    },
    "views": {
      "kiro-acp": [
        {
          "type": "webview",
          "id": "kiro-acp.chatView",
          "name": ""
        }
      ]
    },
    "commands": [
      {
        "command": "kiro-acp.newSession",
        "title": "Kiro: New Chat Session"
      },
      {
        "command": "kiro-acp.cancelRequest",
        "title": "Kiro: Cancel Current Request"
      }
    ],
    "configuration": {
      "title": "Kiro ACP",
      "properties": {
        "kiro-acp.cliPath": {
          "type": "string",
          "default": "",
          "description": "kiro-cli の絶対パス（空の場合は PATH から検索）"
        },
        "kiro-acp.traceRpc": {
          "type": "boolean",
          "default": true,
          "description": "ACPのJSON-RPC送受信をOutput(Kiro ACP)へ詳細出力する"
        }
      }
    }
  },
  "scripts": {
    "compile": "pnpm run check-types && node esbuild.mjs",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.mjs --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "vscode:prepublish": "pnpm run package",
    "package": "pnpm run check-types && node esbuild.mjs --production"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "esbuild": "^0.25.0",
    "eslint": "latest",
    "eslint-config-prettier": "latest",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "prettier": "latest",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "lucide-react": "^0.576.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
